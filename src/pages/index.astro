---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Parys Saint-Barber — Barber Shop w Centrum"
  description="Parys Saint-Barber to profesjonalny barber shop oferujący strzyżenie, pielęgnację brody i stylizację. Umów wizytę już dziś."
>

  <!-- ═══════════════════════════════════════════════════
       1. HERO
  ════════════════════════════════════════════════════ -->
  <section class="hero-section relative flex flex-col items-center justify-center text-center px-4 py-20 min-h-screen overflow-hidden">

    <!-- Background layers -->
    <div class="hero-bg absolute inset-0 z-0"></div>
    <div class="hero-pattern absolute inset-0 z-0 opacity-10"></div>
    <div class="hero-vignette absolute inset-0 z-0"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-6 max-w-2xl mx-auto">

      <img
        src="/parys_logo_final.svg"
        alt="Parys Saint-Barber"
        width="240"
        height="240"
        class="max-w-[180px] md:max-w-xs w-full drop-shadow-2xl"
      />

      <div class="flex flex-col gap-3">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight tracking-tight">
          Twój styl.<br />
          <span class="text-accent-gold">Nasza pasja.</span>
        </h1>
        <br class="text-base md:text-xl text-white/75 font-light tracking-wide">
          Profesjonalny barber, złote dziecko barberstwa. </br><span class="text-accent-gold text-3xl font-bold">THE GOAT</span>
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 mt-2 w-full sm:w-auto justify-center">
        <a
          href="/kontakt"
          class="inline-block px-8 py-3.5 bg-accent-red text-white font-semibold rounded-sm tracking-wide hover:bg-accent-red/90 active:scale-95 transition-all duration-200 shadow-lg shadow-accent-red/30 text-sm md:text-base"
        >
          Umów wizytę
        </a>
        <a
          href="/realizacje"
          class="inline-block px-8 py-3.5 border-2 border-accent-gold text-accent-gold font-semibold rounded-sm tracking-wide hover:bg-accent-gold/10 active:scale-95 transition-all duration-200 text-sm md:text-base"
        >
          Zobacz realizacje
        </a>
      </div>

    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1 text-white/40">
      <span class="text-xs tracking-widest uppercase">Przewiń</span>
      <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════
       2. SERVICES
  ════════════════════════════════════════════════════ -->
  <section class="py-20 px-4 bg-bg-base dark:bg-bg-dark">
    <div class="max-w-5xl mx-auto">

      <!-- Section header -->
      <div class="text-center mb-14">
        <span class="text-accent-red uppercase text-xs font-semibold tracking-[0.2em]">Co oferujemy</span>
        <h2 class="mt-2 text-3xl md:text-4xl font-bold text-gray-900 dark:text-text-dark">
          Nasze usługi
        </h2>
        <div class="mt-4 mx-auto w-12 h-0.5 bg-accent-gold"></div>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Card 1: Strzyżenie -->
        <article class="service-card group flex flex-col items-center text-center p-8 rounded-sm
          bg-white dark:bg-bg-surface-dark
          border-t-[3px] border-t-accent-gold
          shadow-sm hover:shadow-xl dark:shadow-accent-blue/20
          hover:-translate-y-1 transition-all duration-300">
          <div class="mb-5 p-4 rounded-full bg-accent-red/8 dark:bg-accent-red/15 group-hover:bg-accent-red/15 transition-colors duration-300">
            <svg class="w-8 h-8 text-accent-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M14.121 14.121A3 3 0 1 1 9.88 9.88m8.659-7.53a3 3 0 1 1-4.243 4.242M6.343 6.343l11.314 11.314M6.343 6.343 3.515 3.515M17.657 17.657l2.828 2.828M9.879 9.879 6.343 6.343" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-text-dark mb-3">Strzyżenie</h3>
          <p class="text-gray-500 dark:text-text-dark/60 text-sm leading-relaxed">
            Klasyczne i nowoczesne cięcia dopasowane do Twojej twarzy
          </p>
        </article>

        <!-- Card 2: Broda -->
        <article class="service-card group flex flex-col items-center text-center p-8 rounded-sm
          bg-white dark:bg-bg-surface-dark
          border-t-[3px] border-t-accent-gold
          shadow-sm hover:shadow-xl dark:shadow-accent-blue/20
          hover:-translate-y-1 transition-all duration-300">
          <div class="mb-5 p-4 rounded-full bg-accent-gold/10 dark:bg-accent-gold/15 group-hover:bg-accent-gold/20 transition-colors duration-300">
            <svg class="w-8 h-8 text-accent-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M9 4.5v15m6-15v15M5.25 9h13.5M5.25 15h13.5M3 4.5h18M3 19.5h18" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-text-dark mb-3">Broda</h3>
          <p class="text-gray-500 dark:text-text-dark/60 text-sm leading-relaxed">
            Strzyżenie, modelowanie i pielęgnacja brody
          </p>
        </article>

        <!-- Card 3: Styling -->
        <article class="service-card group flex flex-col items-center text-center p-8 rounded-sm
          bg-white dark:bg-bg-surface-dark
          border-t-[3px] border-t-accent-gold
          shadow-sm hover:shadow-xl dark:shadow-accent-blue/20
          hover:-translate-y-1 transition-all duration-300">
          <div class="mb-5 p-4 rounded-full bg-accent-blue/8 dark:bg-accent-blue/25 group-hover:bg-accent-blue/15 transition-colors duration-300">
            <svg class="w-8 h-8 text-accent-blue dark:text-accent-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-text-dark mb-3">Styling</h3>
          <p class="text-gray-500 dark:text-text-dark/60 text-sm leading-relaxed">
            Kompletny styling i pielęgnacja włosów
          </p>
        </article>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       3. ABOUT
  ════════════════════════════════════════════════════ -->
  <section class="py-20 px-4 bg-bg-surface dark:bg-bg-surface-dark">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Facebook Reel -->
        <div class="relative">
          <div class="about-img-border absolute -inset-3 rounded-sm opacity-30"></div>
          <div class="about-reel-wrapper">
            <video
              src="/reelparys.mp4"
              poster="/reelparys-poster.jpg"
              muted
              loop
              playsinline
              preload="none"
              class="about-reel-video"
              aria-label="Parys Saint-Barber — rolka wideo"
            ></video>
            <button class="about-play-btn" aria-label="Odtwórz wideo">
              <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
          <!-- Gold accent bar -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 border-4 border-accent-gold rounded-sm z-0 opacity-60"></div>
        </div>

        <!-- Text -->
        <div class="flex flex-col gap-5">
          <span class="text-accent-red uppercase text-xs font-semibold tracking-[0.2em]">O nas</span>

          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-text-dark leading-tight">
            Parys<br /><span class="text-accent-gold">Saint-Barber</span>
          </h2>

          <div class="w-10 h-0.5 bg-accent-red"></div>

          <div class="flex flex-col gap-4 text-gray-600 dark:text-text-dark/70 text-sm md:text-base leading-relaxed">
            <p>
              Pasja do rzemiosła barberskiego to fundament wszystkiego, co robimy. Od pierwszego cięcia po ostatni detal
              — każda wizyta to doświadczenie, które zostawia niezatarte wrażenie.
            </p>
            <p>
              Łączymy klasyczne techniki barbera z nowoczesnym podejściem do stylu, dbając o to, by każdy klient
              wychodził z naszego fotela pewniejszy siebie i doskonale wyglądający.
            </p>
            <p>
              Inspirowani duchem Paryża i estetyką PSG — precyzja, elegancja i charakter to nasze znaki firmowe.
              Nie tworzymy fryzur — tworzymy styl.
            </p>
          </div>

          <!-- PSG-inspired tagline -->
          <blockquote class="border-l-4 border-accent-gold pl-4 text-accent-gold font-semibold italic text-sm md:text-base">
            "Prestiż jest w szczegółach."
          </blockquote>

          <a
            href="/kontakt"
            class="mt-2 self-start inline-flex items-center gap-2 px-7 py-3 bg-accent-blue dark:bg-accent-gold dark:text-bg-dark text-white font-semibold rounded-sm text-sm tracking-wide hover:opacity-90 active:scale-95 transition-all duration-200 shadow-md"
          >
            Skontaktuj się
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       4. CTA BANNER
  ════════════════════════════════════════════════════ -->
  <section class="cta-banner py-20 px-4 relative overflow-hidden">

    <!-- Background decoration -->
    <div class="absolute inset-0 cta-bg z-0"></div>
    <div class="cta-pattern absolute inset-0 z-0 opacity-5"></div>

    <div class="relative z-10 max-w-3xl mx-auto text-center flex flex-col items-center gap-6">

      <span class="inline-block px-4 py-1 border border-accent-gold/50 text-accent-gold text-xs uppercase tracking-[0.2em] rounded-full">
        Zarezerwuj teraz
      </span>

      <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight">
        Gotowy na nowy look?
      </h2>

      <p class="text-white/70 text-base md:text-lg max-w-xl leading-relaxed">
        Zarezerwuj wizytę i przekonaj się, na czym polega prawdziwy barber experience.
      </p>

      <a
        href="/kontakt"
        class="inline-flex items-center gap-2 px-10 py-4 bg-white text-bg-dark font-bold rounded-sm text-sm md:text-base tracking-wide hover:bg-accent-gold hover:text-white active:scale-95 transition-all duration-200 shadow-xl"
      >
        Umów wizytę
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       SCOPED STYLES
  ════════════════════════════════════════════════════ -->
  <style>
    /* ── Hero ── */
    .hero-section {
      background-color: #001a35;
    }

    .hero-bg {
      background: linear-gradient(
        135deg,
        #001a35 0%,
        #002850 40%,
        #001428 70%,
        #0a0a12 100%
      );
    }

    .hero-pattern {
      background-image:
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent 40px,
          rgba(206, 171, 93, 0.15) 40px,
          rgba(206, 171, 93, 0.15) 41px
        ),
        repeating-linear-gradient(
          90deg,
          transparent,
          transparent 40px,
          rgba(206, 171, 93, 0.08) 40px,
          rgba(206, 171, 93, 0.08) 41px
        );
    }

    .hero-vignette {
      background: radial-gradient(
        ellipse at center,
        transparent 30%,
        rgba(0, 10, 20, 0.7) 100%
      );
    }

    /* ── About image border ── */
    .about-img-border {
      background: linear-gradient(135deg, #ceab5d, #DA291C, #004170);
    }

    /* ── About reel wrapper ── */
    .about-reel-wrapper {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 360px;
      aspect-ratio: 267 / 476;
      margin-inline: auto;
      overflow: hidden;
      border-radius: 2px;

      & .about-play-btn {
        position: absolute;
        inset: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.35);
        border: none;
        cursor: pointer;
        transition: background 0.2s;

        & svg {
          width: 4rem;
          height: 4rem;
          color: white;
          filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
        }

        &.playing {
          background: transparent;

          & .icon-play { display: none; }

          &:hover {
            background: rgba(0, 0, 0, 0.35);
          }
        }

        &:hover {
          background: rgba(0, 0, 0, 0.5);
        }
      }
    }

    /* ── CTA Banner ── */
    .cta-banner {
      background-color: #001a35;
    }

    .cta-bg {
      background: linear-gradient(
        135deg,
        #001a35 0%,
        #002850 50%,
        #DA291C 150%
      );
    }

    .cta-pattern {
      background-image: radial-gradient(
        circle at 20% 50%,
        rgba(218, 41, 28, 0.3) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 50%,
        rgba(206, 171, 93, 0.2) 0%,
        transparent 50%
      );
      opacity: 0.4;
    }
  </style>

  <script>
    const btn = document.querySelector('.about-play-btn') as HTMLButtonElement | null;
    const video = document.querySelector('.about-reel-video') as HTMLVideoElement | null;
    if (btn && video) {
      btn.addEventListener('click', () => {
        if (video.paused) {
          video.play();
          btn.classList.add('playing');
          btn.setAttribute('aria-label', 'Zatrzymaj wideo');
        } else {
          video.pause();
          btn.classList.remove('playing');
          btn.setAttribute('aria-label', 'Odtwórz wideo');
        }
      });
    }
  </script>

</BaseLayout>
