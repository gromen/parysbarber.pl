---
import GalleryGrid from '../components/GalleryGrid.astro';
import Lightbox from '../components/Lightbox.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const images = [
  { src: 'https://picsum.photos/seed/barber1/600/750',  thumb: 'https://picsum.photos/seed/barber1/400/500',  alt: 'Realizacja 1',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber2/600/750',  thumb: 'https://picsum.photos/seed/barber2/400/500',  alt: 'Realizacja 2',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber3/600/750',  thumb: 'https://picsum.photos/seed/barber3/400/500',  alt: 'Realizacja 3',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber4/600/750',  thumb: 'https://picsum.photos/seed/barber4/400/500',  alt: 'Realizacja 4',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber5/600/750',  thumb: 'https://picsum.photos/seed/barber5/400/500',  alt: 'Realizacja 5',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber6/600/750',  thumb: 'https://picsum.photos/seed/barber6/400/500',  alt: 'Realizacja 6',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber7/600/750',  thumb: 'https://picsum.photos/seed/barber7/400/500',  alt: 'Realizacja 7',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber8/600/750',  thumb: 'https://picsum.photos/seed/barber8/400/500',  alt: 'Realizacja 8',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber9/600/750',  thumb: 'https://picsum.photos/seed/barber9/400/500',  alt: 'Realizacja 9',  width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber10/600/750', thumb: 'https://picsum.photos/seed/barber10/400/500', alt: 'Realizacja 10', width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber11/600/750', thumb: 'https://picsum.photos/seed/barber11/400/500', alt: 'Realizacja 11', width: 600, height: 750 },
  { src: 'https://picsum.photos/seed/barber12/600/750', thumb: 'https://picsum.photos/seed/barber12/400/500', alt: 'Realizacja 12', width: 600, height: 750 },
];
---

<BaseLayout
  title="Realizacje — Parys Saint-Barber"
  description="Galeria prac Parys Saint-Barber. Nasze strzyżenia i stylizacje mówią same za siebie."
>
<section class="reels-section">
    <div class="reels-inner">
    <h1 class="text-4xl font-bold text-center mb-4 font-playfair">Realizacje</h1>

      <p class="reels-subheading">Obejrzyj nas w akcji</p>
      <div class="reels-grid">
        <div class="reel-wrapper">
          <video
            src="/reelparys.mp4"
            poster="/reelparys-poster.jpg"
            muted
            loop
            playsinline
            preload="none"
            aria-label="Parys Saint-Barber — rolka wideo"
            class="reel-video"
            style="width:100%;height:100%;object-fit:cover;display:block;"
          ></video>
          <button class="reel-play-btn" aria-label="Odtwórz wideo">
            <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-4 max-w-7xl mx-auto hidden">
    <h2 class="text-4xl font-bold text-center mb-4 font-playfair">Galeria</h2>
    <p class="text-center text-gray-600 dark:text-gray-400 mb-12">
      Nasze prace mówią same za siebie
    </p>
    <GalleryGrid images={images} />
  </section>

  <Lightbox />

  <script>
    document.querySelectorAll<HTMLElement>('.reel-wrapper').forEach(wrapper => {
      const btn = wrapper.querySelector<HTMLButtonElement>('.reel-play-btn');
      const video = wrapper.querySelector<HTMLVideoElement>('.reel-video');
      if (btn && video) {
        btn.addEventListener('click', () => {
          if (video.paused) {
            video.play();
            btn.classList.add('playing');
            btn.setAttribute('aria-label', 'Zatrzymaj wideo');
          } else {
            video.pause();
            btn.classList.remove('playing');
            btn.setAttribute('aria-label', 'Odtwórz wideo');
          }
        });
      }
    });
  </script>
</BaseLayout>

<style>
  .reels-section {
    padding: 3rem 1rem;

    & .reels-inner {
      max-width: 80rem;
      margin-inline: auto;
    }

    & .reels-heading {
      font-size: 1.75rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 0.5rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    & .reels-subheading {
      text-align: center;
      color: #6b7280;
      margin-bottom: 2.5rem;

      @media (prefers-color-scheme: dark) {
        color: #9ca3af;
      }
    }

    & .reels-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
    }

    & .reel-wrapper {
      position: relative;
      width: 100%;
      max-width: 267px;
      aspect-ratio: 267 / 476;
      overflow: hidden;

      & .reel-play-btn {
        position: absolute;
        inset: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.35);
        border: none;
        cursor: pointer;
        transition: background 0.2s;

        & svg {
          width: 4rem;
          height: 4rem;
          color: white;
          filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
        }

        &.playing {
          background: transparent;

          & .icon-play { display: none; }

          &:hover {
            background: rgba(0, 0, 0, 0.35);
          }
        }

        &:hover {
          background: rgba(0, 0, 0, 0.5);
        }
      }
    }

    @media (min-width: 640px) {
      padding: 4rem 2rem;

      & .reels-heading {
        font-size: 2rem;
      }

      & .reel-wrapper {
        width: 267px;
        height: 476px;
        aspect-ratio: unset;
        flex-shrink: 0;
      }
    }

    @media (min-width: 1024px) {
      padding: 5rem 2rem;
    }
  }
</style>
