---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBar from '../components/CookieBar.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="pl" class="" id="html-root">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Anti-flash theme init — must be first script in <head> -->
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        } catch (e) {}
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BarberShop",
      "name": "Parys Saint-Barber",
      "url": "https://parysbarber.pl",
      "telephone": "+48696083037",
      "email": "parysbarber@gmail.com",
      "image": "https://parysbarber.pl/parys_logo_final.svg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "ul. Tadeusza Kościuszki 38E/5U",
        "addressLocality": "Ostrów Mazowiecka",
        "postalCode": "07-300",
        "addressCountry": "PL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 52.33321,
        "longitude": 20.99827
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "09:00",
          "closes": "18:00"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/paryssaintbarber/",
        "https://www.facebook.com/parysbarber/"
      ]
    })} />
  </head>

  <body class="bg-bg-base dark:bg-bg-dark text-gray-900 dark:text-text-dark min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
    <CookieBar />

    <!-- GTM — loads only after cookie consent -->
    <script is:inline>
      (function () {
        var GTM_ID = 'GTM-PHMLWWVN';
        var loaded = false;
        var isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

        function loadGTM() {
          if (loaded || isLocal) return;
          loaded = true;
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0];
            var j = d.createElement(s);
            var dl = l !== 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', GTM_ID);
        }

        if (localStorage.getItem('cookieConsent') === 'accepted') {
          loadGTM();
        }

        window.addEventListener('cookieConsentGiven', loadGTM);
      })();
    </script>
  </body>
</html>
