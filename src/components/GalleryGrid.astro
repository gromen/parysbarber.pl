---
interface Props {
  images: Array<{
    src: string;
    thumb: string;
    alt: string;
    width: number;
    height: number;
  }>;
}

const { images } = Astro.props;
const galleryData = JSON.stringify(images.map((img) => ({ src: img.src, alt: img.alt })));
---

<div
  id="gallery-grid"
  class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-1"
  data-gallery-images={galleryData}
>
  {
    images.map((image, index) => (
      <button
        type="button"
        class="gallery-item group relative overflow-hidden aspect-[4/5] w-full cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-gold"
        data-lightbox
        data-index={index}
        aria-label={`Otwórz zdjęcie: ${image.alt}`}
      >
        <img
          src={image.thumb}
          alt={image.alt}
          width={image.width}
          height={image.height}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-300 ease-in-out group-hover:scale-105"
        />
        <span class="absolute inset-0 border-2 border-transparent group-hover:border-accent-gold transition-colors duration-300 pointer-events-none" />
        <span class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 pointer-events-none" />
      </button>
    ))
  }
</div>
