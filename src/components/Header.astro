---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Strona główna' },
  { href: '/realizacje', label: 'Realizacje' },
  { href: '/kontakt', label: 'Kontakt' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-40 bg-white/95 dark:bg-bg-surface-dark backdrop-blur-sm border-b-2 border-accent-red shadow-sm">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" aria-label="Parys Saint-Barber - strona główna" class="shrink-0">
      <img
        src="/parys_logo_final.svg"
        alt="Parys Saint-Barber"
        class="h-10 w-auto"
        width="160"
        height="40"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Nawigacja główna">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors duration-200 relative py-1',
            'after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-accent-gold after:transition-transform after:duration-200',
            isActive(href)
              ? 'text-accent-gold dark:text-accent-gold after:scale-x-100'
              : 'text-gray-700 dark:text-text-dark hover:text-accent-gold dark:hover:text-accent-gold after:scale-x-0 hover:after:scale-x-100',
          ]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Right side: theme toggle + hamburger -->
    <div class="flex items-center gap-2">
      <ThemeToggle />

      <!-- Hamburger button (mobile only) -->
      <button
        id="hamburger-btn"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden p-2 rounded text-gray-700 dark:text-text-dark hover:bg-gray-100 dark:hover:bg-bg-dark transition-colors"
      >
        <svg id="icon-hamburger" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden border-t border-gray-200 dark:border-bg-dark bg-white dark:bg-bg-surface-dark"
    aria-label="Nawigacja mobilna"
  >
    <ul class="flex flex-col px-4 py-3 gap-1">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-2 px-3 rounded text-sm font-medium transition-colors duration-200',
              isActive(href)
                ? 'text-accent-gold bg-accent-gold/10 dark:bg-accent-gold/10'
                : 'text-gray-700 dark:text-text-dark hover:text-accent-gold hover:bg-gray-50 dark:hover:bg-bg-dark',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-16"></div>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconHamburger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  let isOpen = false;

  hamburgerBtn?.addEventListener('click', () => {
    isOpen = !isOpen;
    mobileMenu?.classList.toggle('hidden', !isOpen);
    hamburgerBtn.setAttribute('aria-expanded', String(isOpen));
    hamburgerBtn.setAttribute('aria-label', isOpen ? 'Zamknij menu' : 'Otwórz menu');
    iconHamburger?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      isOpen = false;
      mobileMenu.classList.add('hidden');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      hamburgerBtn?.setAttribute('aria-label', 'Otwórz menu');
      iconHamburger?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
