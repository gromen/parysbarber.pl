---
const year = new Date().getFullYear();
---

<footer class="bg-gray-100 dark:bg-bg-dark border-t border-gray-200 dark:border-bg-surface-dark mt-auto">
  <div class="max-w-6xl mx-auto px-4 pt-10 pb-8 flex flex-col items-center gap-6">
    <!-- Logo -->
    <a href="/" aria-label="Parys Saint-Barber - strona główna">
      <img
        src="/parys_logo_final.svg"
        alt="Parys Saint-Barber"
        class="h-16 w-auto"
        width="256"
        height="64"
      />
    </a>

    <div class="w-12 h-px bg-accent-gold/40"></div>

    <div class="w-full flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
    <!-- Copyright + Author credit -->
    <div class="text-center sm:text-left">
      <p class="text-sm text-gray-600 dark:text-text-dark/70">
        &copy; {year} Parys Saint-Barber. Wszelkie prawa zastrzeżone.
      </p>
      <!-- Author credit -->
    <p class="text-xs text-gray-500 dark:text-text-dark/50 flex items-center gap-1.5 mt-4">
      Realizacja:
      Marcin Gromek
      <a
        href="https://gromek.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 hover:text-accent-gold transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
